{
  "name": "nand2tetris web-ide",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "25",
      "nodeGypDependencies": true
    },
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "onCreateCommand": "sudo npx --yes playwright@1.52.0 install-deps chromium",
  "postCreateCommand": "mkdir -p /home/vscode/.cache/ms-playwright && sudo chown -R vscode:vscode /home/vscode/.cache/ms-playwright && npm ci && npm run playwright:install",
  "forwardPorts": [5173],
  "portsAttributes": {
    "5173": {
      "label": "Vite dev server",
      "onAutoForward": "notify"
    }
  },
  "remoteUser": "vscode"
}

{
  "name": "@nand2tetris/web",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "author": "David Souther <davidsouther@gmail.com>",
  "license": "ISC",
  "homepage": "https://nand2tetris.github.io/web-ide",
  "devDependencies": {
    "@davidsouther/jiffies": "^2.2.5",
    "@lingui/babel-plugin-lingui-macro": "^5.0.0",
    "@lingui/cli": "^5.0.0",
    "@lingui/macro": "^5.0.0",
    "@lingui/react": "^5.0.0",
    "@lingui/vite-plugin": "^5.0.0",
    "@monaco-editor/react": "^4.6.0",
    "@nand2tetris/components": "file:../components",
    "@nand2tetris/projects": "file:../projects",
    "@nand2tetris/simulator": "file:../simulator",
    "@testing-library/jest-dom": "^6.4.5",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/error-cause": "^1.0.4",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.1.2",
    "immer": "^10.1.1",
    "jszip": "^3.10.1",
    "make-plural": "^7.4.0",
    "ohm-js": "^17.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-ga4": "^2.1.0",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.23.1",
    "remark-gfm": "^4.0.0",
    "rxjs": "^7.8.1",
    "sass": "^1.77.4",
    "source-map-explorer": "^2.5.3",
    "vite": "^6.3.3",
    "vitest": "^3.1.2"
  },
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "postbuild": "node ./scripts/predeploy.js",
    "test": "vitest run",
    "prebuild": "npm run extract && npm run lingui",
    "extract": "lingui extract",
    "lingui": "lingui compile --namespace es"
  },
  "browserslist": {
    "production": [
      ">1%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lingui": {
    "locales": [
      "en",
      "en-PL"
    ],
    "sourceLocale": "en",
    "pseudoLocale": "en-PL",
    "fallbackLocales": {
      "en-PL": "en"
    },
    "catalogs": [
      {
        "path": "src/locales/{locale}/messages",
        "include": [
          "src",
          "public"
        ]
      }
    ],
    "format": "po"
  }
}
